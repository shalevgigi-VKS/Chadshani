rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    // All data areas — read/write only for authenticated users
    match /tasks/{id}      { allow read, write: if isAuthed(); }
    match /shopping/{id}   { allow read, write: if isAuthed(); }
    match /vouchers/{id}   { allow read, write: if isAuthed(); }
    match /money/{id}      { allow read, write: if isAuthed(); }
    match /bills/{id}      { allow read, write: if isAuthed(); }
    match /goals/{id}      { allow read, write: if isAuthed(); }
    match /documents/{id}  { allow read, write: if isAuthed(); }
    match /history/{id}    { allow read, write: if isAuthed(); }
    match /pushTokens/{id} { allow read, write: if isAuthed(); }
  }
}
