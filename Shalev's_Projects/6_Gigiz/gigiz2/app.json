{
  "expo": {
    "name": "גיגיז",
    "slug": "gigiz",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gigiz.app",
      "infoPlist": {
        "NSCameraUsageDescription": "גיגיז צריכה גישה למצלמה לסריקת מסמכים",
        "NSPhotoLibraryUsageDescription": "גיגיז צריכה גישה לגלריה לבחירת מסמכים"
      }
    },
    "android": {
      "package": "com.gigiz.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "scheme": "gigiz",
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "shalevgigi",
    "extra": {
      "eas": {
        "projectId": "b543abf2-1831-4780-a75e-cebfe1681558"
      },
      "router": {
        "origin": false
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b543abf2-1831-4780-a75e-cebfe1681558"
    }
  }
}
